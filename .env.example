# ============================================================
# GEMA Azure Blob Storage Classification Worker – Umgebungsvariablen
# ============================================================

# --- Auth -----------------------------------------------------------
# device_code      = Browser-Login via Device Code (empfohlen fuer lokalen Docker-Test)
# default          = DefaultAzureCredential (az login lokal / Managed Identity in Azure)
# connection_string = nur fuer lokalen Notfall – kein Secret ins Repo!
AUTH_MODE=device_code

# --- Azure Ressourcen -----------------------------------------------
AZURE_STORAGE_ACCOUNT=stgemaclasspilot001
SOURCE_CONTAINER=cool-stage-test
REPORT_CONTAINER=reports
QUARANTINE_CONTAINER=quarantine-test
WORKER_VERSION=pilot-v0.1

# --- Worker Defaults ------------------------------------------------
WORKER_NAME=Andre3000
DEFAULT_MAX_FILES=50
DEFAULT_PREFIX=_root_part000/
UPLOAD_REPORTS=true

# --- Dashboard (liest aus Azure) ------------------------------------
DASHBOARD_REPORT_SOURCE=azure

# --- KI (standardmaessig deaktiviert) -------------------------------
ENABLE_AI=false
AI_PROVIDER=none
# AI_PROVIDER=groq         (aktiviert Groq Free Tier)
# AI_PROVIDER=foundry      (aktiviert Azure AI Foundry)
AI_POLICY_MODE=conservative
AI_MAX_CALLS_PER_RUN=10
AI_MAX_CHARS_PER_FILE=2000
AI_MAX_TOTAL_CHARS_PER_RUN=20000
AI_MIN_CONFIDENCE_THRESHOLD=60
AI_MODEL=llama-3.3-70b-versatile
AI_PROMPT_VERSION=v1
AI_TEMPERATURE=0
AI_MAX_OUTPUT_TOKENS=300
AI_WRITE_TAGS=false

# Token-Schätzung Safety Factor (reale Tokens ca. 34-36% über raw-Schätzung)
AI_TOKEN_ESTIMATION_SAFETY_FACTOR=1.5

# PDF Extraktion: max. Seiten pro Datei
PDF_MAX_PAGES=3

# --- Azure AI Foundry (nur wenn AI_PROVIDER=foundry) ----------------
# AI_FOUNDRY_ENDPOINT=https://<resource>.openai.azure.com/
# AI_FOUNDRY_MODEL_DEPLOYMENT=gpt-4o
# AI_FOUNDRY_API_VERSION=2024-02-01
# AI_FOUNDRY_API_KEY=<nur fuer lokale Tests, nie einchecken!>

# --- Nur fuer lokale Tests (nicht einchecken!) ----------------------
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# GROQ_API_KEY secret - NEVER commit to repo, NEVER log, NEVER in dashboard:
# GROQ_API_KEY=gsk_...
